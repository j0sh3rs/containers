{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'docker:enableMajor',
    'helpers:pinGitHubActionDigests',
    ':automergeBranch',
    ':dependencyDashboard',
    ':semanticCommits',
    ':timezone(America/New_York)',
  ],
  dependencyDashboardTitle: 'Renovate Dashboard 🤖',
  // Renovate owns every container's inputs — both the base images (node,
  // python, uv) and the underlying packages each one installs (the claude-code
  // npm CLI, the omega-memory PyPI wheel). The old bespoke updater
  // (scripts/check-upstream.sh + .github/workflows/schedule.yaml) that managed
  // claude-code has been retired so there is a single, uniform updater.
  packageRules: [
    // Scope claude-code's PRs (node base + the npm CLI version) so commits read
    // `chore(claude-code): ...`. The Dockerfile ARG and ci/values.yaml version
    // are the same dep (@anthropic-ai/claude-code), so they land in one PR.
    {
      matchFileNames: ['containers/claude-code/**'],
      semanticCommitScope: 'claude-code',
    },
    // Group the omega-mcp image's three pinned inputs (python base, uv, the
    // omega-memory wheel) so bumps land as reviewable, related PRs.
    {
      matchFileNames: ['containers/omega-mcp/**'],
      semanticCommitScope: 'omega-mcp',
    },
    // onnxruntime/sqlite-vec ship no musl wheels; the base MUST stay glibc.
    // Pin the python base to the 3.x line so renovate offers minor/patch but
    // never silently jumps a major across a possible ABI/extra break.
    {
      matchFileNames: ['containers/omega-mcp/**'],
      matchDepNames: ['python'],
      matchUpdateTypes: ['major'],
      enabled: false,
    },
  ],
  customManagers: [
    // claude-code's ci/values.yaml carries the upstream npm version, which the
    // build reads to tag the image and pass as CLAUDE_CODE_VERSION. The
    // Dockerfile ARG is matched by its inline `# renovate:` comment (auto);
    // this regex keeps the values.yaml `version` field in lockstep so the tag
    // and the installed CLI never diverge.
    {
      customType: 'regex',
      managerFilePatterns: ['/containers/claude-code/ci/values\\.yaml$/'],
      matchStrings: [
        'version:\\s*"(?<currentValue>[^"]+)"',
      ],
      depNameTemplate: '@anthropic-ai/claude-code',
      datasourceTemplate: 'npm',
    },
    // omega-mcp's ci/values.yaml carries the omega-memory PyPI version that the
    // build passes as the OMEGA_VERSION arg and uses for the image tag.
    // Renovate's built-in managers don't know this bespoke schema, so match it
    // by regex.
    {
      customType: 'regex',
      managerFilePatterns: ['/containers/omega-mcp/ci/values\\.yaml$/'],
      matchStrings: [
        'version:\\s*"(?<currentValue>[^"]+)"',
        'OMEGA_VERSION:\\s*"(?<currentValue>[^"]+)"',
      ],
      depNameTemplate: 'omega-memory',
      datasourceTemplate: 'pypi',
    },
  ],
}
